<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SmartFoldering.FolderDialogWindow"
        Width="400" SizeToContent="Height"
        Background="#18181A"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner">

    <Border Padding="25" PointerPressed="Window_PointerPressed" CornerRadius="12" BorderBrush="#2C2C2E" BorderThickness="1">
        <StackPanel Spacing="20">
            <TextBlock Text="Folder Details" FontSize="18" FontWeight="Bold" Foreground="#FFFFFF" Margin="0,0,0,5"/>

            <StackPanel Spacing="8">
                <TextBlock Text="Folder Name" Foreground="#8E8E93" FontSize="12" FontWeight="SemiBold"/>
                <TextBox x:Name="NameTextBox" Background="#1C1C1E" Foreground="#F2F2F7" BorderBrush="#3A3A3C" Padding="12" CornerRadius="6" Watermark="e.g. Downloads"/>
            </StackPanel>

            <StackPanel Spacing="8">
                <TextBlock Text="Folder Path" Foreground="#8E8E93" FontSize="12" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="*, Auto">
                    <TextBox Grid.Column="0" x:Name="PathTextBox" Background="#1C1C1E" Foreground="#F2F2F7" BorderBrush="#3A3A3C" IsReadOnly="True" Padding="12" CornerRadius="6" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="..." Width="45" Height="42" Background="#2C2C2E" Foreground="#D1D1D6" Click="BrowseFolder_Click" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" CornerRadius="6"/>
                </Grid>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="12" Margin="0,15,0,0">
                <Button Content="Cancel" Width="90" Padding="10" Background="Transparent" Foreground="#8E8E93" Click="Cancel_Click" HorizontalContentAlignment="Center"/>
                <Button Content="Save" Width="90" Padding="10" Background="#48484A" Foreground="#FFFFFF" FontWeight="Bold" CornerRadius="6" Click="Save_Click" HorizontalContentAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>